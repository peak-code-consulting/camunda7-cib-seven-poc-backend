  "item": [
    {
      "name": "Get Access Tokens",
      "item": [
        {
          "name": "Alice (Employee)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Tests tab - runs automatically after receiving the response",
                  "",
                  "// 1. Save the access token to an environment/collection variable",
                  "pm.environment.set(\"access_token\", pm.response.json().access_token);",
                  "",
                  "// Optional: also save refresh token if you plan to use it later",
                  "pm.environment.set(\"refresh_token\", pm.response.json().refresh_token);",
                  "",
                  "// Optional: save when it expires (useful for debugging)",
                  "const expiresIn = pm.response.json().expires_in;",
                  "const expiresAt = Date.now() + (expiresIn * 1000);",
                  "pm.environment.set(\"token_expires_at\", expiresAt);",
                  "",
                  "// Nice-to-have: console log for debugging",
                  "console.log(\"Access token saved → \" + pm.environment.get(\"access_token\").substring(0,15) + \"...\");",
                  "console.log(\"Expires in \" + expiresIn + \" seconds\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "type": "text",
                  "key": "username",
                  "value": "alice"
                },
                {
                  "type": "text",
                  "key": "password",
                  "value": "alice123"
                },
                {
                  "type": "text",
                  "key": "grant_type",
                  "value": "password"
                },
                {
                  "type": "text",
                  "key": "client_id",
                  "value": "camunda-app"
                },
                {
                  "type": "text",
                  "key": "client_secret",
                  "value": "change-this-secret"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:7508/realms/camunda-realm/protocol/openid-connect/token",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "7508",
              "path": [
                "realms",
                "camunda-realm",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          },
          "response": []
        },
