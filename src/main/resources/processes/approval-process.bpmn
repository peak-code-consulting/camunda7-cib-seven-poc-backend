  <bpmn:process id="approval-process" name="Approval Process" isExecutable="true" camunda:historyTimeToLive="3600">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1et4ven</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_SubmitRequest" name="Submit Request" camunda:assignee="alice" camunda:candidateGroups="employee">
      <bpmn:incoming>Flow_1et4ven</bpmn:incoming>
      <bpmn:outgoing>Flow_0z67h8y</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1et4ven" sourceRef="StartEvent_1" targetRef="Activity_SubmitRequest" />
    <bpmn:exclusiveGateway id="Gateway_AmountCheck" name="Amount Check">
      <bpmn:incoming>Flow_0z67h8y</bpmn:incoming>
      <bpmn:outgoing>Flow_0rgryu5</bpmn:outgoing>
      <bpmn:outgoing>Flow_0fjhzp4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0z67h8y" sourceRef="Activity_SubmitRequest" targetRef="Gateway_AmountCheck" />
    <bpmn:userTask id="Activity_ManagerApproval" name="Manager Approval" camunda:assignee="bob" camunda:candidateGroups="manager">
      <bpmn:incoming>Flow_0rgryu5</bpmn:incoming>
      <bpmn:outgoing>Flow_1o52c24</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0rgryu5" name="High Amount" sourceRef="Gateway_AmountCheck" targetRef="Activity_ManagerApproval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${amount &gt; 1000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Activity_0h3q8vd" name="Mark As Done" camunda:assignee="diana" camunda:candidateGroups="employee">
      <bpmn:incoming>Flow_0fjhzp4</bpmn:incoming>
      <bpmn:incoming>Flow_1o52c24</bpmn:incoming>
      <bpmn:outgoing>Flow_06esy2u</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0fjhzp4" name="Low Amount" sourceRef="Gateway_AmountCheck" targetRef="Activity_0h3q8vd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${amount &lt;= 1000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1o52c24" sourceRef="Activity_ManagerApproval" targetRef="Activity_0h3q8vd" />
    <bpmn:endEvent id="Event_0wl7m6o">
      <bpmn:incoming>Flow_06esy2u</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_06esy2u" sourceRef="Activity_0h3q8vd" targetRef="Event_0wl7m6o" />
  </bpmn:process>
